{
  "name": "303-show",
  "version": "0.1.0",
  "description": "303.show — the fastest way to see what's playing in Denver tonight",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "node pipeline/fetch-and-build.mjs && vite build",
    "build:site": "vite build",
    "data": "node pipeline/fetch-and-build.mjs",
    "data:mock": "node pipeline/fetch-and-build.mjs --mock",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.8.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "svelte": "^5.1.0",
    "svelte-check": "^4.0.0",
    "vite": "^5.4.0"
  }
}
